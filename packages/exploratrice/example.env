# Are search robots allowed to index this site?
ALLOW_ROBOTS=false

# Assemblée PostgreSQL database configuration
ASSEMBLEE_DB_NAME="assemblee"
ASSEMBLEE_DB_HOST="localhost"
ASSEMBLEE_DB_PORT=5432
ASSEMBLEE_DB_USER="assemblee"
# Change value of DB_PASSWORD!
ASSEMBLEE_DB_PASSWORD="assemblee"

# Path of repository containing repository of Assemblée documents
# in various formats (HTML, PDF, etc)
ASSEMBLEE_DOCUMENTS_DIR="../../../assemblee-data/Documents/"

# Grist configuration
GRIST_API_KEY="your-grist-api-key"
GRIST_DOC_ID="your-grist-doc-id"
GRIST_INSTANCE_URL="https://grist.code4code.eu"

# Legi PostgreSQL database configuration
LEGI_DB_NAME="legi"
LEGI_DB_HOST="localhost"
LEGI_DB_PORT=5432
LEGI_DB_USER="legi"
# Change value of DB_PASSWORD!
LEGI_DB_PASSWORD="legi"

LINK_URL_ORIGIN_REPLACEMENT="http://localhost:5173"

# Tisseuse PostgreSQL database configuration
TISSEUSE_DB_NAME="tisseuse"
TISSEUSE_DB_HOST="localhost"
TISSEUSE_DB_PORT=5432
TISSEUSE_DB_USER="tisseuse"
# Change value of DB_PASSWORD!
TISSEUSE_DB_PASSWORD="tisseuse"

TITLE="Recherche Tricoteuses (exemple)"
