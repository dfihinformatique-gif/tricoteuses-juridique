{
  "name": "@tricoteuses/exploratrice",
  "description": "Web application to navigate between French legislative documents",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
