    "@sveltejs/adapter-node": "^5.3.3",
    "@sveltejs/kit": "2.47",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@tricoteuses/assemblee": "^2.4.1",
    "@tricoteuses/legifrance": "^0.17.0",
    "@types/node": "^24.9.0",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
