{
  "name": "@tricoteuses/tisseuse",
  "description": "Find links in/to French legislative documents",
  "version": "0.8.0",
  "keywords": [
    "Assemblée nationale",
    "France",
    "Légifrance",
    "law",
    "open data",
    "Parliament",
    "Sénat"
  ],
  "author": "Emmanuel Raviart <emmanuel@raviart.com>",
  "bugs": {
    "url": "https://git.tricoteuses.fr/logiciels/tricoteuses-juridique/issues"
  },
  "homepage": "https://tricoteuses.fr/",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://git.tricoteuses.fr/logiciels/tricoteuses-juridique.git"
  },
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "!dist/server",
    "!**/*.test.js"
  ],
  "exports": {
    ".": {
      "typedoc": "./src/lib/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./server": {
      "typedoc": "./src/server/index.ts",
      "import": "./dist/server.js",
      "types": "./dist/lib/server/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "configure": "tsx src/scripts/configure.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "npm run test:unit -- --run",
    "test:unit": "vitest"
  },
  "devDependencies": {
    "@auditors/core": "^0.7.4",
    "@tricoteuses/assemblee": "^2.5.21",
    "@tricoteuses/legifrance": "^0.17.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.8.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "dedent-js": "^1.0.1",
    "dotenv": "^17.2.2",
    "eslint": "^9.38.0",
    "fs-extra": "^11.3.1",
    "postgres": "^3.4.7",
    "prettier": "^3.0.0",
    "sade": "^1.8.1",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0",
    "vite": "^7.1.10",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.1"
  }
}
